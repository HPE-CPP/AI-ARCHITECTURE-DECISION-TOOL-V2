# ============================================================
#  REDIS (Upstash)
#  Use rediss:// for SSL (required by Upstash)
# ============================================================
REDIS_URL=redis-cli --tls -u redis://default:gQAAAAAAAS22AAIgcDJiMjZiYjI5YzQ5YzQ0Y2RkOGMyYWM5ODA4ZGU4OGQyMg@amazed-civet-77238.upstash.io:6379
REDIS_TOKEN=gQAAAAAAAS22AAIgcDJiMjZiYjI5YzQ5YzQ0Y2RkOGMyYWM5ODA4ZGU4OGQyMg 

# ============================================================
#  LLM - OpenAI  (required for cloud analysis + embeddings)
# ============================================================
OPENAI_API_KEY=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

# ============================================================
#  LLM - Ollama  (optional, local only)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ============================================================
#  EMBEDDINGS
# ============================================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_CHUNK_SIZE=500
EMBEDDING_CHUNK_OVERLAP=50

# ============================================================
#  VECTOR STORE (FAISS — local disk)
# ============================================================
VECTOR_DB_TYPE=faiss
FAISS_INDEX_PATH=./faiss_index

# ============================================================
#  APP
# ============================================================
DEBUG=true
MAX_FILE_SIZE_MB=50

# ============================================================
#  CORS — comma-separated list of allowed frontend origins
# ============================================================
CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

FIREBASE_CREDENTIALS_PATH=firebase-service-account.json