# ArchGuide Elite v5.0 — Backend Environment
APP_NAME="ArchGuide — AI Architecture Intelligence"
APP_VERSION=5.0.0
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Database (optional — SQLite used automatically if not set)
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/archguide

# SQLite path (auto-created, no setup needed)
SQLITE_PATH=./archguide.db

# LLM: "openai" or "ollama"  
DEFAULT_LLM_PROVIDER=ollama

# OpenAI (optional)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Ollama (free, local — install from ollama.ai)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Redis (optional)
REDIS_URL=
REDIS_TOKEN=

# Security
SECRET_KEY=archguide-change-in-production-minimum-32-chars

# File Upload
MAX_FILE_SIZE_MB=50
