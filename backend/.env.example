# AI Architecture Decision Platform — Backend Environment Configuration
# Copy this to .env and fill in your values.
# For Railway/cloud deployment, set these as environment variables in your dashboard.

# ============================================================
#  DATABASE (Supabase / Neon PostgreSQL)
#  Format: postgresql://user:password@host:5432/dbname
# ============================================================
DATABASE_URL=postgresql://postgres:your-password@db.supabase.co:5432/postgres

# ============================================================
#  REDIS (Upstash)
#  Use rediss:// for SSL (Upstash always requires SSL)
#  Get your URL from: https://console.upstash.com
# ============================================================
REDIS_URL=rediss://default:your-token@amazed-civet-xxxxx.upstash.io:6379
REDIS_TOKEN=your-upstash-rest-token

# ============================================================
#  LLM - OpenAI  (required for cloud — Ollama won't work in cloud)
# ============================================================
OPENAI_API_KEY=sk-...
DEFAULT_LLM_PROVIDER=openai

# ============================================================
#  EMBEDDINGS
# ============================================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_CHUNK_SIZE=500
EMBEDDING_CHUNK_OVERLAP=50

# ============================================================
#  VECTOR STORE (Qdrant Cloud — persistent across deploys)
#  Get your URL and API key from: https://cloud.qdrant.io
# ============================================================
VECTOR_DB_TYPE=qdrant
QDRANT_URL=https://your-cluster.us-east-1-1.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=architecture_decisions

# ============================================================
#  APP
# ============================================================
DEBUG=false
MAX_FILE_SIZE_MB=50

# ============================================================
#  CORS — comma-separated list of allowed frontend origins
#  Add your Vercel URL here once you have it
# ============================================================
CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# ============================================================
#  FIREBASE ADMIN SDK (for server-side token verification)
#  Option 1 (local dev): path to the JSON key file
#  Option 2 (cloud/Railway): paste the entire JSON as one line
#    Get it from: Firebase Console → Project Settings → Service Accounts
# ============================================================
# FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
